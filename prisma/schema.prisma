generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  NOT_STARTED
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  NOT_FULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum PaymentProvider {
  YOOKASSA
  MOCK
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  CANCELED
  FAILED
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  CANCELLED
}

enum InventoryMovementType {
  ADJUSTMENT
  SALE
  RETURN
  RESERVATION
  RELEASE
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String
  phone             String?
  passwordHash      String
  role              UserRole             @default(USER)
  status            UserStatus           @default(ACTIVE)
  birthday          DateTime?
  favoriteDriver    String?
  favoriteTeam      String?
  acceptedLegalAt   DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  accounts          Account[]
  sessions          Session[]
  addresses         Address[]
  carts             Cart[]
  orders            Order[]
  reviews           Review[]
  favorites         Favorite[]
  giftCardsBought   GiftCard[]           @relation("GiftCardsBought")
  giftCardsRedeemed GiftCard[]           @relation("GiftCardsRedeemed")
  balance           UserBalance?
  balanceEntries    BalanceTransaction[]

  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  remember  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    Product[]           @relation("PrimaryCollection")
  productRefs ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
  @@index([collectionId])
}

model Product {
  id               String              @id @default(cuid())
  slug             String              @unique
  name             String
  description      String
  shortDescription String
  priceCents       Int
  oldPriceCents    Int?
  stock            Int?
  designColors     String[]            @default([])
  colorways        String[]            @default([])
  status           ProductStatus       @default(ACTIVE)
  badge            String              @default("New")
  type             String              @default("T-shirt")
  gender           String              @default("Unisex")
  productKind      String              @default("standard")
  requiresShipping Boolean             @default(true)
  popularity       Int                 @default(75)
  categoryId       String?
  collectionId     String?
  driverName       String?
  driverSlug       String?
  teamName         String?
  teamSlug         String?
  legendName       String?
  legendSlug       String?
  number           Int?
  hexPalette       String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  category         Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collection       Collection?         @relation("PrimaryCollection", fields: [collectionId], references: [id], onDelete: SetNull)
  collections      ProductCollection[]
  images           ProductImage[]
  variants         ProductVariant[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  reviews          Review[]
  favorites        Favorite[]

  @@index([status])
  @@index([categoryId])
  @@index([collectionId])
  @@index([createdAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Size {
  id        String           @id @default(cuid())
  value     String           @unique
  label     String
  sortOrder Int              @default(0)
  variants  ProductVariant[]
}

model Color {
  id        String           @id @default(cuid())
  value     String           @unique
  label     String
  hex       String?
  sortOrder Int              @default(0)
  variants  ProductVariant[]
}

model ProductVariant {
  id                 String              @id @default(cuid())
  productId          String
  sizeId             String
  colorId            String
  sku                String              @unique
  stock              Int                 @default(0)
  priceOverrideCents Int?
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  size               Size                @relation(fields: [sizeId], references: [id])
  color              Color               @relation(fields: [colorId], references: [id])
  cartItems          CartItem[]
  orderItems         OrderItem[]
  stockLogs          InventoryMovement[]

  @@unique([productId, sizeId, colorId])
  @@index([productId])
  @@index([sizeId])
  @@index([colorId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  color     String
  size      String
  quantity  Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, color, size])
  @@index([productId])
  @@index([variantId])
}

model Address {
  id             String   @id @default(cuid())
  userId         String
  country        String
  city           String
  street         String
  house          String
  apartment      String   @default("")
  postalCode     String
  recipient      String
  recipientPhone String
  courierComment String   @default("")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[]  @relation("ShippingAddress")

  @@index([userId])
}

model Order {
  id                        String               @id @default(cuid())
  orderNumber               String               @unique
  userId                    String?
  status                    OrderStatus          @default(PENDING)
  paymentStatus             PaymentStatus        @default(NOT_STARTED)
  fulfillmentStatus         FulfillmentStatus    @default(NOT_FULFILLED)
  customerName              String
  customerEmail             String
  customerPhone             String
  shippingAddressId         String?
  deliveryAddressSnapshot   Json?                @map("shippingAddressSnapshot")
  deliveryMethod            String
  paymentMethod             String
  comment                   String               @default("")
  subtotalAmount            Int                  @map("subtotalCents")
  discountAmount            Int                  @default(0)
  deliveryAmount            Int                  @default(0) @map("shippingCostCents")
  totalAmount               Int                  @map("totalCents")
  currency                  String               @default("RUB")
  amountPaidByBalanceCents  Int                  @default(0)
  amountPaidByExternalCents Int                  @default(0)
  balanceBeforeCents        Int                  @default(0)
  balanceAfterCents         Int                  @default(0)
  usedBalance               Boolean              @default(false)
  stockDeducted             Boolean              @default(false)
  stockDeductedAt           DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  user                      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress           Address?             @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items                     OrderItem[]
  payment                   Payment?
  refunds                   Refund[]
  webhookEvents             WebhookEvent[]
  giftCards                 GiftCard[]
  balanceEntries            BalanceTransaction[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([createdAt])
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String?
  variantId        String?
  productSlug      String
  productName      String
  variantName      String          @default("")
  sku              String?
  imageUrl         String          @map("productImage")
  productType      String
  productKind      String
  requiresShipping Boolean         @default(true)
  color            String
  size             String
  quantity         Int
  unitPrice        Int             @map("unitPriceCents")
  totalPrice       Int             @map("lineTotalCents")
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String          @unique
  provider          PaymentProvider @default(MOCK)
  providerPaymentId String?         @map("externalId")
  idempotenceKey    String          @unique
  status            PaymentStatus   @default(NOT_STARTED)
  amount            Int             @map("amountCents")
  currency          String          @default("RUB")
  confirmationUrl   String?
  paidAt            DateTime?
  capturedAt        DateTime?
  canceledAt        DateTime?
  refundedAt        DateTime?
  receiptRequired   Boolean         @default(false)
  receiptStatus     String?
  receipt           Json?
  rawRequest        Json?
  rawResponse       Json?
  webhookPayload    Json?
  errorCode         String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds           Refund[]
  webhookEvents     WebhookEvent[]

  @@index([provider, providerPaymentId])
  @@index([status])
  @@index([createdAt])
}

model Refund {
  id               String       @id @default(cuid())
  paymentId        String
  orderId          String
  providerRefundId String?      @unique
  amount           Int
  currency         String       @default("RUB")
  status           RefundStatus @default(PENDING)
  reason           String?
  rawResponse      Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  payment          Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([orderId])
  @@index([providerRefundId])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventId     String?
  dedupeKey   String          @unique
  eventType   String
  paymentId   String?
  orderId     String?
  payload     Json
  processed   Boolean         @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime        @default(now())
  payment     Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  order       Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([paymentId])
  @@index([orderId])
  @@index([processed])
}

model PromoCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  description         String?
  discountPercent     Int?
  discountAmountCents Int?
  active              Boolean   @default(true)
  startsAt            DateTime?
  endsAt              DateTime?
  maxUses             Int?
  usedCount           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model GiftCard {
  id                String         @id @default(cuid())
  code              String         @unique
  amountCents       Int
  status            GiftCardStatus @default(ACTIVE)
  purchasedByUserId String?
  redeemedByUserId  String?
  orderId           String?
  createdAt         DateTime       @default(now())
  redeemedAt        DateTime?
  expiresAt         DateTime?
  purchasedBy       User?          @relation("GiftCardsBought", fields: [purchasedByUserId], references: [id], onDelete: SetNull)
  redeemedBy        User?          @relation("GiftCardsRedeemed", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  order             Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([purchasedByUserId])
  @@index([redeemedByUserId])
  @@index([orderId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  title     String?
  body      String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  variantId String
  type      InventoryMovementType
  quantity  Int
  note      String?
  createdAt DateTime              @default(now())
  variant   ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model UserBalance {
  userId      String   @id
  amountCents Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BalanceTransaction {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  amountCents        Int
  balanceBeforeCents Int
  balanceAfterCents  Int
  certificateCode    String?
  orderId            String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order              Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
}
