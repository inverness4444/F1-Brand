# Public site origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000
# Set to false for preview/staging deployments that should not be indexed.
NEXT_PUBLIC_SITE_INDEXABLE=true

# Neon PostgreSQL / Prisma
# Runtime app connection: use the pooled Neon URL (host contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@EP-POOLER.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require&connection_limit=1&pool_timeout=20&connect_timeout=15&max_idle_connection_lifetime=60"
# Prisma Migrate connection: use the direct Neon URL (same endpoint without "-pooler").
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@EP.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
# Optional runtime pool override. Keep low for serverless/local Next.js processes.
PRISMA_CONNECTION_LIMIT=1

# Server auth. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Seed/demo admin account. Use only for local development or controlled staging seeds.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345!
SEED_USER_EMAIL=customer@example.com
SEED_USER_PASSWORD=Customer12345!
SEED_CREATE_TEST_ORDER=false

# YooKassa server-only credentials. Leave empty for local mock mode.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/checkout/success
YOOKASSA_WEBHOOK_SECRET=

# Optional receipt/54-FZ config. Enable only after online cash register settings are confirmed.
YOOKASSA_RECEIPT_ENABLED=false
YOOKASSA_VAT_CODE=
YOOKASSA_TAX_SYSTEM_CODE=
YOOKASSA_PAYMENT_SUBJECT=
YOOKASSA_PAYMENT_MODE=

# Local mock payment confirmation is disabled in production unless explicitly enabled.
ENABLE_MOCK_PAYMENTS=false

# Optional distributed rate limiting for production/serverless. Upstash Redis REST env names are also supported.
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
