# Public site origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon PostgreSQL / Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
# Optional: direct, non-pooled Neon URL if you keep a separate migration connection.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Server auth. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Seed/demo admin account
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin12345!

# Optional comma-separated emails that may self-register as admins.
ADMIN_EMAILS=
NEXT_PUBLIC_ADMIN_EMAILS=
